ANTHROPIC_API_KEY=
GITHUB_TOKEN=
DATABASE_URL=sqlite+aiosqlite:///./dev.db
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
# Sentry error tracking — leave empty to disable
SENTRY_DSN=
# Required to access /api/ops/summary and private history in non-public deployments.
ADMIN_API_KEY=
ATLAS_JWT_SECRET=
# Optional: enables cross-process public route rate limits in production.
REDIS_URL=
# Comma-separated direct proxy IPs allowed to supply X-Forwarded-For.
TRUSTED_PROXY_HOSTS=127.0.0.1,::1
# Set true only if public recent-run history should be visible.
EXPOSE_PUBLIC_HISTORY=false
# Worker runtime tuning
WORKER_POLL_INTERVAL_SECONDS=2.0
WORKER_STALE_JOB_SECONDS=1800
WORKER_QUEUE_ORDER=atlas,review
OPS_WORKER_QUEUE_ALERT_SECONDS=120
