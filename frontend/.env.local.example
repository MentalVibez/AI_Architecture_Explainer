# Exposed to the browser (client components)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Sentry error tracking — leave empty to disable
NEXT_PUBLIC_SENTRY_DSN=
# Public homepage integrations. Keep disabled unless the matching backend routes are public.
NEXT_PUBLIC_SHOW_PUBLIC_HISTORY=false
NEXT_PUBLIC_SHOW_OPS_SNAPSHOT=false

# Used by server components only — set to internal service URL in production
# Falls back to NEXT_PUBLIC_API_URL if not set
API_URL=http://localhost:8000
# Sentry source map upload — only needed during build on CI/Vercel
SENTRY_AUTH_TOKEN=
