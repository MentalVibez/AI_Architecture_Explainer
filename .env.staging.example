# Copy this to .env.staging on your home server and fill in real values.
# Never commit .env.staging — it contains secrets.

ANTHROPIC_API_KEY=
GITHUB_TOKEN=
DATABASE_URL=sqlite+aiosqlite:///./staging.db
ENVIRONMENT=staging
CORS_ORIGINS=http://localhost:3000
ADMIN_API_KEY=
ATLAS_JWT_SECRET=
REDIS_URL=
TRUSTED_PROXY_HOSTS=127.0.0.1,::1
EXPOSE_PUBLIC_HISTORY=false
NEXT_PUBLIC_API_URL=http://localhost:8000
