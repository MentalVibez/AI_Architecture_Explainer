# Copy this to .env.staging on your home server and fill in real values.
# Never commit .env.staging — it contains secrets.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# GitHub OAuth app credentials (create at github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Postgres + pgvector ───────────────────────────────────────────────────────
# Used by docker-compose to create the database and build the connection URL.
# For company-hosted Postgres, set DATABASE_URL directly and leave these blank.
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=atlas

# Set DATABASE_URL only when using an external (company-provided) Postgres.
# If blank, docker-compose injects the URL from the POSTGRES_* vars above.
DATABASE_URL=

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=staging
CORS_ORIGINS=http://localhost:3000,https://atlas.company.internal

# Secret key for JWT signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ATLAS_JWT_SECRET=

# Column-level encryption key for raw_evidence (opt-in, leave blank to disable).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: losing this key makes encrypted records permanently unreadable.
#          Store it in your password manager alongside the DB backup key.
ATLAS_FIELD_ENCRYPTION_KEY=

# GitHub OAuth callback URL — must match what is registered on GitHub.
ATLAS_OAUTH_REDIRECT_URI=https://atlas.company.internal/api/auth/callback

# ── Ops ───────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=
REDIS_URL=
TRUSTED_PROXY_HOSTS=127.0.0.1,::1
EXPOSE_PUBLIC_HISTORY=false
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_STALE_SECONDS=90

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://atlas.company.internal
